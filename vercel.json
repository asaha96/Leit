{
  "crons": [
    {
      "path": "/api/cron/keep-alive",
      "schedule": "0 8 */2 * *"
    }
  ],
  "rewrites": [
    { "source": "/api/cron/:path*", "destination": "/api/cron/:path*" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
